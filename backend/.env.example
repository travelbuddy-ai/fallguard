# Copy this file to .env and fill in your values.

# Tuya IoT Platform credentials
# Get these from https://iot.tuya.com → Cloud → Project → Overview
TUYA_BASE_URL=https://openapi.tuyaus.com
TUYA_CLIENT_ID=your_access_id_here
TUYA_CLIENT_SECRET=your_access_secret_here

# The Tuya device ID of the T5AI board registered in your project
TUYA_DEVICE_ID=your_device_id_here

# Where to save fall snapshot images (default: ./snapshots)
# SNAPSHOTS_DIR=snapshots

# Server port (default: 8080)
# PORT=8080
