# FallGuard Backend — no Tuya credentials needed here.
# All Tuya Cloud communication is handled directly by the T5AI firmware.

# Where to save fall snapshot images (default: ./snapshots)
# SNAPSHOTS_DIR=snapshots

# Server port (default: 8080)
# PORT=8080

# Telegram bot alerts (optional)
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# TELEGRAM_CHAT_ID=your_chat_id
